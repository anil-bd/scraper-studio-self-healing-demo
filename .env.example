# Get your API key from https://brightdata.com/cp/setting/users
BRIGHTDATA_API_KEY=

# Pre-wired demo collector + URLs (a public Bright Data sample shop).
# Replace with your own to demo healing on a different scraper.
COLLECTOR_ID=c_moh0s3kp1udrdi454s

# Self-healing instructions (max 1000 chars). Describe what to fix.
HEAL_PROMPT=The product page selectors are broken after a recent site update. Update the scraper so it correctly extracts product title, price, image, and description from the new DOM.

# Comma-separated target URLs.
TEST_URL=https://ecommerce-shop-brd.vercel.app/product/aurora-wireless-headphones,https://ecommerce-shop-brd.vercel.app/product/everyday-cotton-tee,https://ecommerce-shop-brd.vercel.app/product/kiln-ceramic-mug

# Trigger options
QUEUE_NEXT=1

# Poll cadence (ms) and overall timeout (ms) for heal job + scrape jobs.
POLL_INTERVAL_MS=5000
POLL_TIMEOUT_MS=600000

# Optional: comma-separated field names that MUST be present and non-empty in
# every scraped row for the result to count as healthy. Case-insensitive.
# Leave blank to use the default "any non-input field is non-empty" check.
# Example: REQUIRED_FIELDS=title,price,image
REQUIRED_FIELDS=
