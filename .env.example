# Get your API key from https://brightdata.com/cp/setting/users
BRIGHTDATA_API_KEY=

# Your existing Scraper Studio collector / template ID to demo healing on.
COLLECTOR_ID=

# Self-healing instructions (max 1000 chars). Describe what to fix.
HEAL_PROMPT=Fix broken selectors after the recent site update and make the scraper resilient to minor DOM changes.

# Comma-separated target URL(s) the scraper should run against.
TEST_URL=

# Trigger options
QUEUE_NEXT=1

# Poll cadence (ms) and overall timeout (ms) for heal job + scrape jobs.
POLL_INTERVAL_MS=5000
POLL_TIMEOUT_MS=600000

# Optional: comma-separated field names that MUST be present and non-empty in
# every scraped row for the result to count as healthy. Case-insensitive.
# Leave blank to use the default "any non-input field is non-empty" check.
# Example: REQUIRED_FIELDS=title,price,image
REQUIRED_FIELDS=
